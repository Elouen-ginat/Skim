# syntax=docker/dockerfile:1
# Generated by `skaal build --target local`. Do not edit manually.
# Build context is the artifacts directory (self-contained: main.py, pyproject.toml, source package).
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Create the data directory used by SQLite and any other file-backed backends.
# aiosqlite will fail with OperationalError if this directory is absent.
RUN mkdir -p /app/data

# Install `uv` to sync dependencies from pyproject.toml
RUN pip install --no-cache-dir uv

# Copy artifact files early so the mesh/ presence check below works correctly.
COPY . .

# If a Rust mesh extension is bundled, install the toolchain so uv can compile it.
# The apt cache is mounted so packages survive across builds.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    if [ -d "mesh" ]; then \
        apt-get update && apt-get install -y --no-install-recommends curl build-essential \
        && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal; \
    fi

ENV PATH="/root/.cargo/bin:$${PATH}"

# Install runtime dependencies. The uv package cache and Rust crate registry are
# mounted so only changed packages are re-downloaded on subsequent builds.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    uv sync --no-dev

# Ensure /app is in Python path so gunicorn can find main.py and the source package
ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["uv", "run", "gunicorn", "--bind", "0.0.0.0:8000", "--workers", "2", "--timeout", "120"$gunicorn_worker, "main:application"]
