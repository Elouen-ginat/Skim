[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{name}"
version = "0.1.0"
description = "A Skaal app."
requires-python = ">=3.11"
dependencies = [
    "skaal[serve]",
]

[tool.hatch.build.targets.wheel]
packages = ["{name}"]

[tool.skaal]
app = "{name}.app:app"
target = "local"
